{
  "workbench.colorTheme": "Little Moon (light)",
  "workbench.preferredLightColorTheme": "Little Moon (light)",
  "workbench.preferredDarkColorTheme": "Little Moon (dark)",
  "workbench.colorCustomizations": {
    "editorInlayHint.background": "#009c8f10",
  },
  "cSpell.userWords": [
    "boid",
    "boids",
    "Brusse",
    "clipring",
    "cmds",
    "cognito",
    "enqueues",
    "enumerables",
    "esbenp",
    "executables",
    "fieldless",
    "gameplay",
    "hardcode",
    "hardcoded",
    "includable",
    "includables",
    "initialisms",
    "multiclip",
    "pagedown",
    "pageup",
    "Pirrone",
    "postgres",
    "recurse",
    "rustfmt",
    "selenized",
    "Targeter",
    "timeseries",
    "transpile",
    "transpiled",
    "unconfigured",
  ],
  "editor.renderWhitespace": "selection",
  "editor.rulers": [50, 70, 78, 80, 100, 120, 160],
  "editor.cursorBlinking": "phase",
  "editor.dragAndDrop": false,
  "editor.fontFamily": "Source Code Pro",
  "explorer.enableDragAndDrop": false,
  "explorer.autoReveal": false,
  "explorer.excludeGitIgnore": false,
  "files.hotExit": "onExitAndWindowClose",
  "debug.allowBreakpointsEverywhere": true,
  "terminal.integrated.scrollback": 100000,
  "trailing-spaces.highlightCurrentLine": false,
  "editor.wordWrapColumn": 100,
  "gitlens.defaultDateFormat": "YYYY MMMM D, H:mm",
  "gitlens.defaultDateShortFormat": "YYYY MMM D",
  "gitlens.codeLens.enabled": false,
  "git.detectWorktrees": true,
  "clipring.selectTextAfterPasteFromMenu": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.editor.navigationScope": "editorGroup",
  "workbench.editor.empty.hint": "hidden",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[tailwindcss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "security.workspace.trust.untrustedFiles": "open",
  "window.confirmBeforeClose": "keyboardOnly",
  "editor.inlayHints.enabled": "offUnlessPressed",
  // Make the suggestions widget not suck.
  // See the hotkey 'Normalize the Suggest Widget' section
  "editor.suggest.selectionMode": "never",
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.inlineSuggest.showToolbar": "never",
  "editor.acceptSuggestionOnCommitCharacter": false,
  // Other other changes to the suggestions nonsense.
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.inlineSuggest.syntaxHighlightingEnabled": true,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "rust-analyzer.inlayHints.maxLength": null,
  "rust-analyzer.inlayHints.bindingModeHints.enable": true,
  "rust-analyzer.inlayHints.closureCaptureHints.enable": true,
  "rust-analyzer.inlayHints.closureReturnTypeHints.enable": "with_block",
  "rust-analyzer.inlayHints.discriminantHints.enable": "fieldless",
  "rust-analyzer.inlayHints.expressionAdjustmentHints.enable": "always",
  "rust-analyzer.inlayHints.lifetimeElisionHints.useParameterNames": true,
  "editor.quickSuggestions": {
    "other": "inline",
  },
  // These will likely change based on toggles. Place new setting above.
  "editor.codeLens": false,
  "editor.inlayHints.maximumLength": 0,
  "editor.lineNumbers": "on",
  "zig.path": "zig",
  "zig.zls.path": "/home/dpb/.config/Code/User/globalStorage/ziglang.vscode-zig/zls_install/zls",
  "zig.initialSetupDone": true,
  // "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.formatOnType": true,
  "hexeditor.columnWidth": 16,
  "hexeditor.showDecodedText": true,
  "hexeditor.defaultEndianness": "little",
  "hexeditor.inspectorType": "aside",
  "workbench.editor.labelFormat": "short",
  "editor.lightbulb.enabled": "off",
  "cSpell.diagnosticLevel": "Hint",
  "cSpell.useCustomDecorations": false,
  "editor.wordWrap": "off",
  "[markdown]": {
    "editor.wordWrap": "off",
  },
  "[html]": {
    "editor.wordWrap": "bounded",
    "editor.defaultFormatter": "vscode.html-language-features",
  },
  "editor.minimap.showSlider": "always",
  "window.titleBarStyle": "custom",
  "editor.occurrencesHighlight": "singleFile",
  "diffEditor.hideUnchangedRegions.enabled": true,
  "godotTools.inlayHints.gdscript": true,
  "todo-tree.tree.scanMode": "workspace only",
  "window.customTitleBarVisibility": "auto",
  "todo-tree.highlights.defaultHighlight": {
    "background": "#384c52",
    "opacity": 20,
  },
  "todo-tree.highlights.highlightDelay": 1,
  "rust-analyzer.testExplorer": true,
  "rust-analyzer.runnables.extraEnv": {
    "CARGO_TARGET_DIR": "target/rust-analyzer",
  },
  "[liquid]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.formatOnSave": false,
  },
  "claudeCode.initialPermissionMode": "acceptEdits",
  "claudeCode.preferredLocation": "panel",
  "editor.hover.delay": 400,
  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.focusAboveGroup",
    "workbench.action.focusBelowGroup",
    "workbench.action.focusLeftGroup",
    "workbench.action.focusRightGroup",
  ],
  "editor.minimap.enabled": false,
}

